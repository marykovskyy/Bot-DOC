# ==============================
# TELEGRAM
# ==============================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ADMIN_ID=your_admin_chat_id_here

# Timezone для планувальника задач (розклад, CRON)
# Список: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# Europe/Kyiv = UTC+2 (зима) / UTC+3 (літо, DST)
BOT_TIMEZONE=Europe/Kyiv

# ==============================
# AWS (для Textract у ai_sorter)
# ==============================
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here

# S3 bucket для вивантаження архівів результатів
# Створи bucket: https://s3.console.aws.amazon.com/s3 → "Create bucket"
# Регіон: us-east-1, усі інші налаштування за замовчуванням
AWS_S3_BUCKET_NAME=your_s3_bucket_name_here
AWS_S3_REGION=us-east-1

# Скільки днів зберігати сесії аналізу на Desktop (потім автоочищення)
# Можна змінити вручну: /cleanup 7 — видалити старіші 7 днів
SESSION_KEEP_DAYS=30

# Telegram канал або група для автоматичного отримання результатів (опціонально)
# Формат: числовий ID каналу, наприклад -1001234567890
# Щоб дізнатись ID: перешли будь-яке повідомлення з каналу боту @userinfobot
TG_RESULTS_CHANNEL_ID=

# ==============================
# OPENAI
# ==============================
OPENAI_API_KEY=your_openai_api_key_here

# ==============================
# UK Companies House API
# ==============================
UK_COMPANIES_API_KEY=your_uk_companies_house_api_key_here

# ==============================
# FRANCE — pappers.fr internal API
# ==============================
# Токен знятий із HAR-файлу сайту pappers.fr (Frontend JS token)
# Якщо перестане працювати (401/403) — зайди на pappers.fr,
# відкрий DevTools → Network → знайди запит до api.pappers.ai
# і скопіюй новий api_token з URL запиту.
PAPPERS_API_TOKEN=your_pappers_api_token_here

# ==============================
# GOOGLE SHEETS
# ==============================
GOOGLE_SHEET_URL=your_google_sheet_url_here

GDRIVE_CREDENTIALS_FILE=credentials.json

# ==============================
# GOOGLE DRIVE — папка для результатів
# ==============================
# 1. Відкрий drive.google.com → створи папку (напр. "Bot Results")
# 2. ПКМ на папці → Спільний доступ → додай service account email (роль: Редактор)
# 3. Відкрий папку → скопіюй ID з URL: drive.google.com/drive/folders/ТУТ_ID
# 4. Встав ID нижче:
GDRIVE_RESULTS_FOLDER_ID=your_gdrive_folder_id_here
